# ============================================
# CONFIGURACIÓN DEL BOT DE WHATSAPP (CHAKRA)
# ============================================

# API Key de Chakra (BSP de WhatsApp)
# Obtener en: https://chakrahq.com/ o tu panel de Chakra
# Rol requerido: "Chakra Bot"
CHAKRA_API_KEY=tu_chakra_api_key_aqui

# Plugin ID de Chakra
# Obtener en: Panel de Chakra → WhatsApp Setup → 3 puntos (arriba derecha) → "Copy Plugin Id"
CHAKRA_PLUGIN_ID=tu_plugin_id_aqui

# Versión de la API de WhatsApp (generalmente v18.0)
CHAKRA_WHATSAPP_API_VERSION=v18.0

# Token de verificación del webhook (crea uno seguro)
# Puedes usar cualquier cadena de texto segura
VERIFY_TOKEN=mi_token_seguro_123

# ============================================
# CONFIGURACIÓN DE GOOGLE CALENDAR
# ============================================

# ID del calendario (puede ser 'primary' o el email del calendario)
# Para desarrollo: usa 'primary'
# Para producción: usa el email del calendario compartido
CALENDAR_ID=primary

# Ruta al archivo de credenciales de Google (para desarrollo local)
# Descargar desde: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_PATH=./credentials.json

# OPCIONAL: Si usas Railway, puedes poner el JSON completo aquí en lugar de usar archivo
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ============================================
# CONFIGURACIÓN DE OPENAI
# ============================================

# API Key de OpenAI
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_openai_api_key_aqui

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000
